{
  "layer": "top", // Waybar at top layer
  "position": "top", // Waybar position (top|bottom|left|right)
  "spacing": 4, // Gaps between modules (4px)
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["custom/clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "backlight", "battery", "tray",  "idle_inhibitor"],
  // Modules configuration
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{index} {icon}",
    "format-icons": {
      "focused": "яЖТ",
      "default": "яДС"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "tray": {
    "icon-size": 18,
    "spacing": 4
  },
  "custom/clock": {
    "exec": "echo '  '$(date +'%m-%d ( %a )  %H:%M')'  '",
    "interval": 5
  },
  "cpu": {
    "format": "яЛЫ   {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "яГЙ   {used:0.1f}G / {total:0.1f}G  ({percentage}%)"
  },
  "backlight": {
    "format": "{icon}   {percent}%",
    "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
  },
  "battery": {
    "states": {
      "full": 100,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}    {capacity}%",
    "format-charging": "яЧз   {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{time} {icon}",
    "format-full": "{icon}    {capacity}%",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "pulseaudio": {
    "format": "{icon}   {volume}%   {format_source}",
    "format-bluetooth": "яКФ {icon} {volume}% {format_source}",
    "format-bluetooth-muted": "яКФ яЪй {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "яД░ {volume}%",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАж", "яАз", "яАи"]
    },
    "on-click": "pavucontrol"
  }
}
