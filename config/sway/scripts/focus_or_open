#!/usr/bin/env bash

# アプリケーションごとのsway app_idを指定する関数
get_app_id() {
  case "$1" in
    "google-chrome-stable")
      echo "google-chrome"
      ;;
    "alacritty")
      echo "Alacritty"
      ;;
    "discord")
      echo "discord"
      ;;
    *)
      echo "$1"
      ;;
  esac
}

if [ -z "$1" ]; then
  exit 1
fi

app_command="$1"
app_id=$(get_app_id "$app_command")

# sway treeからapp_idでウィンドウを探してフォーカス
if swaymsg "[app_id=$app_id]" focus 2>/dev/null; then
  :
else
  $app_command
fi
