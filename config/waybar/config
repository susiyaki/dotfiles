{
  "layer": "top", // Waybar at top layer
  "position": "top", // Waybar position (top|bottom|left|right)
  "spacing": 4, // Gaps between modules (4px)
  "modules-left": ["sway/workspaces", "sway/mode", "cpu", "memory", "disk"],
  "modules-center": ["custom/clock"],
  "modules-right": ["custom/screencast", "pulseaudio", "backlight", "battery", "tray", "custom/dnd", "idle_inhibitor"],
  // Modules configuration
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{index} {icon}",
    "format-icons": {
      "focused": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    }
  },
  "tray": {
    "icon-size": 18,
    "spacing": 4
  },
  "custom/clock": {
    "exec": "echo '  '$(LC_TIME=C date +'%-m/%-d %a.  %H:%M')'  '",
    "interval": 5
  },
  "cpu": {
    "format": "ΎΜδ   {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "ΎΔΚ   {used:0.1f}G ({percentage}%)"
  },
  "disk": {
    "interval": 30,
    "format": "ΎΓι   {used} ({percentage_used}%)",
    "path": "/"
  },
  "backlight": {
    "format": "{icon}   {percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
  },
  "battery": {
    "states": {
      "full": 100,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "ΎΩπ  {capacity}% ({power}W)",
    "format-plugged": "ΎΘο {capacity}% ({power}W)",
    "format-alt": "{time} {icon}",
    "format-full": "{icon}  {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  "pulseaudio": {
    "format": "{icon}   {volume}%   {format_source}",
    "format-bluetooth": "ΎΛΦ {icon} {volume}% {format_source}",
    "format-bluetooth-muted": "ΎΛΦ Ύγσ {format_source}",
    "format-muted": "Ύγσ {format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒ ",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },
  "custom/screencast": {
    "exec": "bash ~/.config/waybar/scripts/screencast-indicator.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "bash ~/.config/sway/scripts/capture-manager.sh screencast"
  },
  "custom/dnd": {
    "exec": "bash ~/.config/waybar/scripts/dnd-indicator.sh",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-click": "swaync-client -d"
  }
}
